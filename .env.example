# Database Configuration
# DATABASE_URL: Local PostgreSQL or cloud database connection string.
# Example local docker-compose database URL: postgresql://postgres:postgrespassword@localhost:5432/smart_assets?schema=public
# Example hosted Neon database URL: postgresql://username:password@ep-host-name.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/smart_assets?schema=public"

# NextAuth Configurations
# NEXTAUTH_SECRET: A random secret string used to sign session cookies. 
# You can generate a strong random key using: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_key_change_me_in_production"

# NEXTAUTH_URL: The canonical URL of your deployed application.
# For local development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Integration Keys
# Generate these in the Google Cloud Console (APIs & Services > Credentials > OAuth 2.0 Client IDs)
# Authorized redirect URIs must include: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your_google_oauth_client_id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

# GitHub OAuth Integration Keys
# Generate these in GitHub (Developer Settings > OAuth Apps)
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your_github_oauth_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_client_secret"

# Cloudinary Media Storage Configuration
# Used for storing uploaded profile images.
# Create a free account at https://cloudinary.com to fetch these details from your Console Dashboard.
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
